[gd_resource type="Resource" script_class="UnitData" format=3]

[ext_resource type="Script" path="res://data/unit_data.gd" id="1_unit"]
[ext_resource type="Script" path="res://data/spell.gd" id="2_spell_type"]
[ext_resource type="Script" path="res://core/ai/boss_roi_gobelin.gd" id="3_boss_behavior"]
[ext_resource type="Texture2D" path="res://asset/persephone.png" id="4_sprite"]
[ext_resource type="Resource" path="res://data/spells/boss/jugement_anubis.tres" id="10_spell"]
[ext_resource type="Resource" path="res://data/spells/Necromant/eclat_ombre.tres" id="11_spell"]

[sub_resource type="Resource" id="BossBehavior_main"]
script = ExtResource("3_boss_behavior")
signature_spell = ExtResource("10_spell")
signature_every = 3
enrage_threshold = 0.5
enrage_attack_bonus = 0.35

[sub_resource type="SpriteFrames" id="SpriteFrames_boss"]
animations = [{"frames": [{"duration": 1.0,"texture": ExtResource("4_sprite")}],"loop": true,"name": &"default","speed": 5.0}]

[resource]
script = ExtResource("1_unit")
unit_name = "Anubis"
description = "Boss EXT: taxe le soin et force les boucliers."
team = 1
max_hp = 320
initiative = 13
max_ap = 8
max_mp = 4
attack_power = 20
armure = 50
resist_magique = 90
sprite_frames = SubResource("SpriteFrames_boss")
sprite_scale = 1.0
spells = Array[ExtResource("2_spell_type")]([ExtResource("10_spell"), ExtResource("11_spell")])
ai_behavior = 0
boss_behavior = SubResource("BossBehavior_main")
